{
  "name": "airco-tracking-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:server && pnpm build:web",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.server.json --noEmit --pretty false",
    "test": "pnpm build:server && node --test server-dist/server/*.test.js server-dist/shared/*.test.js",
    "test:e2e": "playwright test",
    "start": "node server-dist/server/server.js",
    "retention:cleanup": "node server-dist/server/retention-cleanup.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "4.13.1",
    "@azure/storage-blob": "12.33.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.13",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12"
  }
}
